# ==============================================================================
# ForgeOS Root Environment Configuration Template
# Copy this file to '.env' and fill in your credentials.
# ==============================================================================

# Core OpenAI API Configuration (Required for actual AI repairs)
OPENAI_API_KEY=

# Model specification (FastAPI backend uses this model for structured outputs)
OPENAI_REPAIR_MODEL=gpt-5.6

# Lower-cost model for evidence-constrained business intelligence briefs
OPENAI_BI_MODEL=gpt-5.6-luna
OPENAI_TIMEOUT_SECONDS=15

# GitHub API credentials (Prevents API rate limiting on Business Intelligence scrapes)
GITHUB_TOKEN=

# Explicit demo-only fallback (disabled by default so unavailable AI is reported, never simulated)
FORGEOS_ALLOW_DEMO_AI_FALLBACK=false

# Git commit author details (Used by the PR builder when committing fixes)
FORGEOS_GIT_AUTHOR_NAME=ForgeOS
FORGEOS_GIT_AUTHOR_EMAIL=forgeos@example.com

# Enables pushing patch branches upstream to repository origin (default is false)
FORGEOS_ENABLE_GIT_PUSH=false

# Next.js API endpoint base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
