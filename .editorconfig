# ==============================================================================
# ForgeOS EditorConfig Configuration
# Enforces coding style and formatting properties in major IDEs and editors.
# ==============================================================================

root = true

# Rules for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python specific indentation rules
[*.py]
indent_style = space
indent_size = 4

# Markdown specific indentation rules
[*.md]
trim_trailing_whitespace = false
