# ==============================================================================
# ForgeOS Git Attributes Configuration
# Forces consistent line endings across macOS, Linux, and Windows systems.
# ==============================================================================

# Set default behavior for all files (auto-detect text vs binary, normalization)
* text=auto

# Force LF line endings for source code files
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env.example text eol=lf

# Explicitly declare binary files (should never be normalized)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
